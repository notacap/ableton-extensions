{
  "name": "@ableton-extensions/sdk",
  "version": "1.0.0-beta.0",
  "description": "TypeScript SDK for building extensions for Ableton products",
  "homepage": "https://ableton.github.io/extensions-sdk",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": "Ableton AG",
  "engines": {
    "node": ">=22.11.0"
  },
  "type": "module",
  "keywords": [
    "ableton",
    "live",
    "extensions",
    "sdk"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsc --noEmit && tsdown --format esm --format cjs",
    "lint": "eslint .",
    "test": "vitest run",
    "typedoc": "typedoc",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "17.6.0",
    "tsdown": "0.21.10",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2",
    "vitest": "4.1.5"
  }
}
