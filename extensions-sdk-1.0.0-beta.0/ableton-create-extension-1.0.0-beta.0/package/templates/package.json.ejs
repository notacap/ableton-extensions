{
  "name": "<%= extensionName %>",
  "version": "1.0.0",
  "main": "<%= entryPoint %>",
  "engines": {
    "node": ">=24.14.1"
  },
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && tsx build.ts --production",
    "build:dev": "tsc --noEmit && tsx build.ts",
    "start": "npm run build:dev && extensions-cli run",
    "package": "npm run build && extensions-cli package"
  },
  "dependencies": {
    "@ableton-extensions/sdk": "<%= sdkDependency %>"
  },
  "devDependencies": {
    "@ableton-extensions/cli": "<%= cliDependency %>",
    "@types/node": "^24.1.0",
    "esbuild": "0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"<% if (needsUI) { -%>,
    "vite": "^6.0.0"
<% } -%>
  }
}
